generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Provider {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  state       String
  zip         String
  programs    String[]
  totalPaid   Float
  riskScore   Int
  anomalies   String[]
  licenseDate DateTime?
  ownerId        String?
  npi            String?
  billingHistory Json     @default("[]")
  createdAt      DateTime @default(now())
}

model Tip {
  id         String   @id @default(cuid())
  providerId String
  content    String
  createdAt  DateTime @default(now())
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  email       String
  affiliation String?
  message     String
  createdAt   DateTime @default(now())
}

model ImprovementIdea {
  id          String   @id @default(uuid())
  name        String?
  email       String?
  title       String
  description String
  source_url  String?
  status      String   @default("pending")
  decision    String?
  createdAt   DateTime @default(now())
}

model Watchlist {
  id          String    @id @default(cuid())
  email       String
  name        String?
  filters     Json
  lastSentAt  DateTime?
  active      Boolean   @default(true)
  tier        String    @default("reporter")
  createdAt   DateTime  @default(now())
}

model StoryFeed {
  id          String   @id @default(cuid())
  type        String
  providerId  String
  headline    String
  detail      String
  delta       Float?
  detectedAt  DateTime @default(now())
  published   Boolean  @default(false)
}

model ProUser {
  id               String   @id @default(cuid())
  email            String   @unique
  tier             String
  stripeCustomerId String?
  stripeSubId      String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
}
